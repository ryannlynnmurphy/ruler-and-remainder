# The Reality Check backend needs these two values.
# Set them in the Vercel project (Settings → Environment Variables) for prod,
# and copy this file to `.env` for local `vercel dev`. Never commit `.env`.

# The site's own Anthropic key — the reading runs server-side with this, so
# readers don't bring a key. Scope it to this project.
ANTHROPIC_API_KEY=sk-ant-...

# Neon serverless Postgres connection string (pooled). Holds the public ledger
# of checks plus the rate-limit counters and feed cache. From the Neon console,
# or `vercel env pull` after adding the Neon integration.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
